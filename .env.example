# Copy to .env and set real values. Do not commit .env.
# Used by admin tooling, tests, and scripts that need to call the API (including log access).

# Required for admin portal login and for accessing system logfiles on www.australianrates.com.
# Same value as the API worker secret (wrangler secret put ADMIN_API_TOKEN).
# GET https://www.australianrates.com/api/home-loan-rates/admin/logs/system?format=jsonl&limit=1000
# Header: Authorization: Bearer <this-token>
ADMIN_API_TOKEN=

# Optional: additional bearer tokens accepted by admin auth (comma-separated).
# ADMIN_API_TOKENS=token-two,token-three

# For npm run test:admin-portal (can equal ADMIN_API_TOKEN or a dedicated test token).
# ADMIN_TEST_TOKEN=

# Override API base for scripts (default: production).
# API_BASE=https://www.australianrates.com
# TEST_URL=http://localhost:8788/

# Cloudflare API (e.g. pages:set-build, fix:cloudflare-dns-tls).
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
