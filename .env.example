# Copy to .env and set real values. Do not commit .env.
# Used by admin tooling, tests, and scripts that need to call the API (including log access).

# Required for admin portal login and for accessing system logfiles on www.australianrates.com.
# Same value as the API worker secret. To sync: in workers/api run "npx wrangler secret put ADMIN_API_TOKEN"
# and paste your token; set ADMIN_API_TOKEN here to that same value; use that token in the browser at /admin/
# GET https://www.australianrates.com/api/home-loan-rates/admin/logs/system?format=jsonl&limit=1000
# Header: Authorization: Bearer <this-token>
ADMIN_API_TOKEN=

# Optional: override URL for npm run refresh:chart-cache (default: production admin POST below).
# CHART_CACHE_REFRESH_URL=https://www.australianrates.com/api/home-loan-rates/admin/chart-cache/refresh

# GitHub Actions (.github/workflows/scheduled-doctor.yml): add ADMIN_API_TOKEN as a repo secret
# (same bearer as production API worker). Doctor run hour + time zone: Admin > Settings (app_config
# doctor_schedule); CI reads GET /api/home-loan-rates/doctor-schedule. On failure, doctor-failure-open-review-pr.yml
# opens a draft PR so Cloudflare Pages / Sourcery / PR checks can run.

# Optional: additional bearer tokens accepted by admin auth (comma-separated).
# ADMIN_API_TOKENS=token-two,token-three

# For npm run test:admin-portal (can equal ADMIN_API_TOKEN or a dedicated test token).
# ADMIN_TEST_TOKEN=

# Override API base for scripts (default: production).
# API_BASE=https://www.australianrates.com
# TEST_URL=http://localhost:8788/

# Optional: archive worker origin for npm run doctor (GET {ORIGIN}/api/health). Warn-only unless doctor --strict-archive.
# ARCHIVE_ORIGIN=https://australianrates-archive-prod.<your-subdomain>.workers.dev

# Cloudflare API (e.g. pages:set-build, fix:cloudflare-dns-tls).
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
# Optional: D1 usage dashboard. Token needs Cloudflare GraphQL Analytics read access.
# CLOUDFLARE_D1_DATABASE_ID=de6d4315-686b-4022-b080-956ca3819976
