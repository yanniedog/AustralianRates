{
  "name": "australianrates",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/shared",
    "prototypes/lightweight-charts",
    "workers/api",
    "workers/archive",
    "workers/mobile-site-qa"
  ],
  "scripts": {
    "install:all": "npm install --workspaces",
    "build": "npm run check:public-assets && npm run check:clarity && npm run build:lightweight-vendor && npm run build:prototype:lightweight-charts && npm run build:site-version",
    "build:lightweight-vendor": "node scripts/build-lightweight-vendor.mjs",
    "build:prototype:lightweight-charts": "npm run build -w prototypes/lightweight-charts",
    "build:site-version": "node write-deploy-version.js",
    "stamp:site-assets": "node write-deploy-version.js",
    "check:site-asset-stamps": "node write-deploy-version.js --check",
    "dev:api": "npm run dev -w workers/api",
    "dev:archive": "npm run dev -w workers/archive",
    "test:api": "npm run test -w workers/api",
    "test:archive": "npm run test -w workers/archive",
    "test:policy": "node scripts/enforce-api-test-policy.js",
    "test:homepage": "node test-homepage.js --suite=smoke",
    "test:homepage:pivot": "node test-homepage.js --suite=pivot",
    "test:homepage:mobile": "node test-homepage.js --suite=mobile",
    "test:homepage:sections": "node test-homepage.js --suite=sections",
    "test:homepage:full": "npm run test:homepage && npm run test:homepage:pivot && npm run test:homepage:mobile && npm run test:homepage:sections",
    "test:layout-integrity": "node test-layout-display-integrity.js",
    "test:mobile-site-qa": "npm run check -w workers/mobile-site-qa",
    "browser-agent": "node browser-agent-launch.js",
    "test:admin-portal": "node test-admin-portal.js",
    "test:chart-ux": "node test-chart-ux.js",
    "test:chart-status-line": "npx tsx tools/node-scripts/src/chart-status-line-verify.ts",
    "test:theme-contrast": "node test-theme-contrast.js",
    "test:table-errors": "node test-table-error-detect.js",
    "test:site": "npm run test:homepage && npm run diagnose:api:smoke",
    "verify": "npm run check:snapshot-kv-sync && node scripts/run-parallel.mjs typecheck:api typecheck:scripts typecheck:mobile-site-qa && npm run check:site-asset-stamps && npm run build && node scripts/run-parallel.mjs test:archive test:api && npm run test:integration -w workers/api",
    "fix:e2e": "node automate-fix-e2e.js",
    "verify:macquarie-td-e2e": "node verify-macquarie-td-e2e.js",
    "verify:macquarie-td-pipeline": "npm run typecheck:api && node scripts/run-parallel.mjs test:api test:archive && npm run verify:macquarie-td-e2e",
    "audit:visual": "node visual-audit.js",
    "capture:mobile-admin": "node capture-mobile-admin.js",
    "diagnose:api": "node diagnose-api.js",
    "diagnose:api:smoke": "node diagnose-api.js --smoke",
    "diagnose:pages": "node diagnose-pages.js",
    "fetch-status-debug-bundle": "node fetch-status-debug-bundle.js",
    "refresh:chart-cache": "node refresh-chart-cache.js",
    "flush:prod-caches": "node flush-production-caches.mjs",
    "flush:prod-caches-full": "node flush-production-caches.mjs --chart-pivot",
    "doctor": "node doctor.js",
    "doctor:holistic": "node doctor.js --with-hosting",
    "doctor:verify": "npm run doctor && node scripts/run-parallel.mjs test:api test:archive && npm run test:homepage:full",
    "diagnose:claude-code-mcp": "node diagnose-claude-code-mcp.js",
    "diagnose": "node diagnose-local.js",
    "diagnose:local": "node diagnose-local.js",
    "diagnose:full": "node diagnose-local.js --with-api",
    "test:logs-api": "node test-logs-api.js",
    "verify:prod-hosting": "node scripts/verify-production-hosting.mjs",
    "verify:prod": "node scripts/verify-prod.mjs",
    "ship:closeout": "node scripts/ship-closeout-remind.mjs",
    "test:verify-prod": "node --test scripts/test/verify-prod.test.mjs",
    "verify:ubank-savings-gap": "node verify-ubank-savings-gap.mjs",
    "fix:cloudflare-dns-tls": "node scripts/fix-cloudflare-dns-tls.js",
    "sync:hard-limits": "node scripts/sync-hard-limits.mjs",
    "check:snapshot-kv-sync": "node scripts/check-snapshot-kv-sync.mjs",
    "pages:set-build": "node set-pages-build-config.js",
    "pages:trigger": "node scripts/trigger-pages-deploy.js",
    "pages:create-full-token": "node create-full-access-token.js",
    "check:public-assets": "node scripts/check-public-assets.js",
    "check:clarity": "node scripts/check-clarity-installation.js",
    "typecheck:scripts": "npx tsc -p tools/node-scripts/tsconfig.json --noEmit",
    "typecheck:mobile-site-qa": "npx tsc -p workers/mobile-site-qa/tsconfig.json --noEmit",
    "typecheck:api": "npm run typecheck -w workers/api",
    "backup:api-db": "node scripts/export-d1-backup.js --db australianrates_api --remote",
    "db:breakdown": "node fetch-db-stats.js",
    "db:summary": "node fetch-db-stats.js --summary",
    "deploy:api": "node scripts/deploy-api.mjs",
    "verify:ubank-fetch": "node scripts/verify-ubank-public-html.mjs",
    "verify:ubank-e2e": "npm run verify:ubank-fetch && node diagnose-api.js",
    "deploy:archive": "npm run deploy -w workers/archive --",
    "git:graph-hygiene": "node scripts/git-graph-hygiene.mjs"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260207.0",
    "esbuild": "^0.27.4",
    "lightweight-charts": "^5.1.0",
    "playwright": "^1.58.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}
